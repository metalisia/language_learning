  "pronunciationGuide": [
    {
      "sound": "à",
      "ipa": "/a/",
      "desc": "Open 'a' as in 'father'. The accent marks stress position."
    },
    {
      "sound": "è",
      "ipa": "/ɛ/",
      "desc": "Open 'e' as in 'bed'. Used in stressed syllables."
    },
    {
      "sound": "é",
      "ipa": "/e/",
      "desc": "Closed 'e' as in 'they' (without the glide)."
    },
    {
      "sound": "ì",
      "ipa": "/i/",
      "desc": "Like 'ee' in 'see'. The accent marks stress."
    },
    {
      "sound": "ò",
      "ipa": "/ɔ/",
      "desc": "Open 'o' as in British 'hot'. Used in stressed syllables."
    },
    {
      "sound": "ù",
      "ipa": "/u/",
      "desc": "Like 'oo' in 'food'. The accent marks stress."
    },
    {
      "sound": "c (before e/i)",
      "ipa": "/tʃ/",
      "desc": "Like 'ch' in 'church'. 'Cena' = 'chena'."
    },
    {
      "sound": "c (before a/o/u)",
      "ipa": "/k/",
      "desc": "Like 'k' in 'cat'. 'Casa' = 'kasa'."
    },
    {
      "sound": "ch",
      "ipa": "/k/",
      "desc": "Always hard 'k' sound. 'Chi' = 'ki', 'che' = 'ke'."
    },
    {
      "sound": "g (before e/i)",
      "ipa": "/dʒ/",
      "desc": "Like 'j' in 'jump'. 'Gelato' = 'jelato'."
    },
    {
      "sound": "g (before a/o/u)",
      "ipa": "/ɡ/",
      "desc": "Like 'g' in 'go'. 'Gatto' = 'gatto'."
    },
    {
      "sound": "gh",
      "ipa": "/ɡ/",
      "desc": "Always hard 'g'. 'Ghiaccio' = 'giattcho'."
    },
    {
      "sound": "gl (before i)",
      "ipa": "/ʎ/",
      "desc": "Like 'lli' in 'million'. 'Figlio' = 'fee-lyo'."
    },
    {
      "sound": "gn",
      "ipa": "/ɲ/",
      "desc": "Like 'ny' in 'canyon'. 'Gnocchi' = 'nyokki'."
    },
    {
      "sound": "sc (before e/i)",
      "ipa": "/ʃ/",
      "desc": "Like 'sh' in 'ship'. 'Pesce' = 'peshe'."
    },
    {
      "sound": "z",
      "ipa": "/ts/ or /dz/",
      "desc": "Either 'ts' as in 'pizza' or 'dz' as in 'zero'."
    },
    {
      "sound": "double consonants",
      "ipa": "(lengthened)",
      "desc": "Hold the sound longer: 'anno' vs 'ano', 'palla' vs 'pala'."
    }
  ],
